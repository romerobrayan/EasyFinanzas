rules_version = '2';

// Tinto — Cloud Firestore security rules.
// All app data lives under users/{uid}/...; a signed-in user can only touch
// their own subtree. Everything else is denied by default.
//
// Paste this in Firebase console → Firestore Database → Rules → Publish
// (see FIREBASE_SETUP.md, step 4).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
