<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- SMS capture (Sprint 3): live receive + one-time bounded backfill.
         Both are gated behind the explicit opt-in in Perfil — nothing is
         read before the user enables the feature. READ_SMS is
         Play-restricted; this is a personally-sideloaded build. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <!-- SMS permissions imply telephony; mark it optional so the app stays
         installable on devices without it (capture simply never fires). -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />
    <!-- Local reminder notifications: alert channel + reboot re-registration. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".TintoApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tinto">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".core.data.capture.SmsCaptureReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Nu notification capture (Sprint 4): the listener binds only after
             the user grants notification access in system settings, and stays
             inert until the explicit opt-in in Perfil. Only the allow-listed
             Nu package is read; everything else is ignored before parsing. -->
        <service
            android:name=".core.data.capture.notification.TintoNotificationListenerService"
            android:exported="false"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".core.data.notifications.ReminderAlarmReceiver"
            android:exported="false" />

        <receiver
            android:name=".core.data.notifications.ReminderBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>

        <!-- Recurring movements (Sprint 5): re-run the catch-up generator after
             reboot and on timezone/clock changes so pending automatic movements
             materialize even without opening the app. -->
        <receiver
            android:name=".core.data.recurring.RecurringBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
